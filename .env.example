# ============================================================
# AuraWear — Environment Variables Reference
# ============================================================
# Copy this file to app-local.properties (for local dev) or
# configure these as environment variables on your deployment
# platform (Render, Railway, Heroku, etc.).
#
# NEVER commit real values to git.
# ============================================================

# ── Database (MySQL / Aiven) ─────────────────────────────────
# Full JDBC connection URL including host, port, and database name.
# Example (local): jdbc:mysql://localhost:3306/aurawear
# Example (Aiven): jdbc:mysql://mysql-xxx.aivencloud.com:PORT/aurawear?ssl-mode=REQUIRED
AURAWEAR_DB_URL=

# MySQL username (use a least-privilege app user, NOT root)
AURAWEAR_DB_USER=

# MySQL password for the above user
AURAWEAR_DB_PASSWORD=

# ── Email / SMTP (Gmail) ─────────────────────────────────────
# Gmail address used as the "from" sender for OTP and order emails
AURAWEAR_EMAIL=

# Gmail App Password (16 chars, generated from Google Account → Security → App Passwords)
# NOTE: This is NOT your regular Gmail password.
AURAWEAR_EMAIL_PASSWORD=

# ── Razorpay Payment Gateway ─────────────────────────────────
# Set to "true" for real (live) payments, "false" for test mode
RAZORPAY_LIVE_MODE=false

# Test mode keys (from Razorpay Dashboard → Test Mode → Settings → API Keys)
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=

# Live mode keys (from Razorpay Dashboard → Live Mode → Settings → API Keys)
# Only required when RAZORPAY_LIVE_MODE=true
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=
