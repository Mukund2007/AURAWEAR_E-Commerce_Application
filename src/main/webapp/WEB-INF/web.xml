<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0"
         metadata-complete="false">

  <display-name>AuraWear E-Commerce Application</display-name>

  <servlet>
    <servlet-name>CheckoutServlet</servlet-name>
    <servlet-class>com.aurawear.controller.CheckoutServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>PaymentSuccessServlet</servlet-name>
    <servlet-class>com.aurawear.controller.PaymentSuccessServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AdminLoginServlet</servlet-name>
    <servlet-class>com.aurawear.controller.AdminLoginServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <servlet-class>com.aurawear.controller.AdminDashboardServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AdminOrdersServlet</servlet-name>
    <servlet-class>com.aurawear.controller.AdminOrdersServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AdminProductsServlet</servlet-name>
    <servlet-class>com.aurawear.controller.AdminProductsServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AdminSettingsServlet</servlet-name>
    <servlet-class>com.aurawear.controller.AdminSettingsServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ReviewServlet</servlet-name>
    <servlet-class>com.aurawear.controller.ReviewServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>CheckoutServlet</servlet-name>
    <url-pattern>/checkout</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>PaymentSuccessServlet</servlet-name>
    <url-pattern>/payment-success</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AdminLoginServlet</servlet-name>
    <url-pattern>/admin/login</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <url-pattern>/admin/dashboard</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AdminOrdersServlet</servlet-name>
    <url-pattern>/admin/orders</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AdminProductsServlet</servlet-name>
    <url-pattern>/admin/products</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AdminSettingsServlet</servlet-name>
    <url-pattern>/admin/settings</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ReviewServlet</servlet-name>
    <url-pattern>/review</url-pattern>
  </servlet-mapping>
</web-app>
